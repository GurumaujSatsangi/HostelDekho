<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/style.css" />
    <link rel="shortcut icon" href="/favicon.png" type="image/x-icon" />
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <title>Floor: <%=floorplan.floor%> | <%=hostel.hostel_name %> | HostelDekho</title>
  <!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-5MFTR651RJ"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-5MFTR651RJ');
</script>
  </head>
  <body>
    <%- include('partials/navbar') %>
    <main class="page-shell">
    
      <div class="card">
        <div class="card-header">
          <p class="card-title" style="margin:0;"><%=hostel.hostel_name %></p>
          <span class="chip">Floor: <%=floorplan.floor%></span>
        </div>
        <div class="card-content" style="align-items:center;">
          <% if(floorplan.link && floorplan.link.length>0) { %>
          
                    <img src="<%= floorplan.link %>" style="max-width: 500px; width:100%;" class="img-fluid" />

<% } else if (floorplan['1_ac'] || floorplan['1_non_ac'] || floorplan['2_ac'] || floorplan['2_non_ac'] || floorplan['3_ac'] || floorplan['3_non_ac'] || floorplan['4_ac'] || floorplan['4_non_ac'] || floorplan['6_ac'] || floorplan['6_non_ac'] || floorplan['8_ac'] || floorplan['8_non_ac']) { %>
    
    <div class="table-responsive">
      <h4>Number of Rooms</h4>
        <table class="table table-bordered">
            
            <thead>
                <tr>
                    <% if (floorplan['1_ac'] > 0) { %> <th>1 Bed AC</th> <% } %>
                    <% if (floorplan['1_non_ac'] > 0) { %> <th>1 Bed NON AC</th> <% } %>
                    <% if (floorplan['2_ac'] > 0) { %> <th>2 Bed AC</th> <% } %>
                    <% if (floorplan['2_non_ac'] > 0) { %> <th>2 Bed NON AC</th> <% } %>
                    <% if (floorplan['3_ac'] > 0) { %> <th>3 Bed AC</th> <% } %>
                    <% if (floorplan['3_non_ac'] > 0) { %> <th>3 Bed NON AC</th> <% } %>
                    <% if (floorplan['4_ac'] > 0) { %> <th>4 Bed AC</th> <% } %>
                    <% if (floorplan['4_non_ac'] > 0) { %> <th>4 Bed NON AC</th> <% } %>
                    <% if (floorplan['6_ac'] > 0) { %> <th>6 Bed AC</th> <% } %>
                    <% if (floorplan['6_non_ac'] > 0) { %> <th>6 Bed NON AC</th> <% } %>
                    <% if (floorplan['8_ac'] > 0) { %> <th>8 Bed AC</th> <% } %>
                    <% if (floorplan['8_non_ac'] > 0) { %> <th>8 Bed NON AC</th> <% } %>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <% if (floorplan['1_ac'] > 0) { %> <td><%= floorplan['1_ac'] %></td> <% } %>
                    <% if (floorplan['1_non_ac'] > 0) { %> <td><%= floorplan['1_non_ac'] %></td> <% } %>
                    <% if (floorplan['2_ac'] > 0) { %> <td><%= floorplan['2_ac'] %></td> <% } %>
                    <% if (floorplan['2_non_ac'] > 0) { %> <td><%= floorplan['2_non_ac'] %></td> <% } %>
                    <% if (floorplan['3_ac'] > 0) { %> <td><%= floorplan['3_ac'] %></td> <% } %>
                    <% if (floorplan['3_non_ac'] > 0) { %> <td><%= floorplan['3_non_ac'] %></td> <% } %>
                    <% if (floorplan['4_ac'] > 0) { %> <td><%= floorplan['4_ac'] %></td> <% } %>
                    <% if (floorplan['4_non_ac'] > 0) { %> <td><%= floorplan['4_non_ac'] %></td> <% } %>
                    <% if (floorplan['6_ac'] > 0) { %> <td><%= floorplan['6_ac'] %></td> <% } %>
                    <% if (floorplan['6_non_ac'] > 0) { %> <td><%= floorplan['6_non_ac'] %></td> <% } %>
                    <% if (floorplan['8_ac'] > 0) { %> <td><%= floorplan['8_ac'] %></td> <% } %>
                    <% if (floorplan['8_non_ac'] > 0) { %> <td><%= floorplan['8_non_ac'] %></td> <% } %>
                </tr>
            </tbody>
        </table>
    </div>

<% } else { %>
              <h4>Oops! It seems we do not have enough data for this floor. Please check back again later.</h4>

              <% } %>


        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <p class="card-title" style="margin:0;">Rooms</p>
                      <p class="muted"><a href="/review/<%=floorplan.id%>"><i class="bi bi-plus-square-dotted"></i>&nbsp; ADD YOUR ROOM</a></p>

        </div>
        <% if(roomdata && roomdata.length > 0){ %>
            <% roomdata.forEach(function(room){ %>
              <div class="card">
<div class="card-header">

<div style="display: flex; gap: 10px; flex-wrap: wrap; margin-top: 16px;">

  <div class=card-title><%= room.room_number %></div>

</div>
 <p class="muted"><%= room.room_type %></p>

</div>
<div class="card-content">
                 <% if(room.jio_speed === 'Poor' || room.jio_speed==='Very Poor') { %>
                      <span class="chip-no">Jio Connection : <%=room.jio_speed %></span>

                        <% } else if(room.jio_speed === 'Good') { %>
                      <span class="chip-mid">Jio Connection : <%=room.jio_speed %></span>

                          <% } else { %>
                      <span class="chip-green">Jio Connection : <%=room.jio_speed %></span>

                          <% } %>


                          <% if(room.airtel_speed === 'Poor' || room.airtel_speed==='Very Poor') { %>
                      <span class="chip-no">Airtel Connection : <%=room.airtel_speed %></span>

                        <% } else if(room.airtel_speed === 'Good') { %>
                      <span class="chip-mid">Airtel Connection : <%=room.airtel_speed %></span>

                          <% } else { %>
                      <span class="chip-green">Airtel Connection : <%=room.airtel_speed %></span>

                          <% } %>

                          <% if(room.vit_wifi_speed === 'Poor' || room.vit_wifi_speed==='Very Poor') { %>
                      <span class="chip-no">Hostel Wifi Connection : <%=room.vit_wifi_speed %></span>

                        <% } else if(room.vit_wifi_speed === 'Good') { %>
                      <span class="chip-mid">Hostel Wifi Connection : <%=room.vit_wifi_speed %></span>

                          <% } else { %>
                      <span class="chip-green">Hostel Wifi Connection : <%=room.vit_wifi_speed %></span>

                          <% } %>
<% if(room.remarks && room.remarks.length>0) { %>

  <span class="chip-blue">Remarks : <%=room.remarks %></span>


<% } %>
</div>
</div><br>

            <% }); %>
        <% } else { %>
          <p class="muted">No Rooms available!</p>
        <% } %>
      </div>
    </main>
    <%- include('partials/footer') %>
  </body>
  <script src="/script.js"></script>
</html>
